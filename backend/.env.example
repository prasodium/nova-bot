# ===== AI provider =====
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Vision + planning model. Fast/cheap default; use claude-opus-4-8 for harder reasoning.
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=600

# ===== Nodes =====
# Where the XIAO ESP32-S3 vision node serves frames (from its serial boot log).
VISION_NODE_URL=http://192.168.1.50
# Backend bind address/port (the main controller connects here).
HOST=0.0.0.0
PORT=8000

# ===== Behaviour =====
# Seconds between "think" ticks (each tick = 1 image + 1 LLM call). Lower = snappier + pricier.
THINK_INTERVAL_S=2.0
# Free-text mission you give the robot. The planner steers toward this.
ROBOT_GOAL=Explore the room safely. Avoid bumping into things. Describe what you see.
# Cap the robot's speed (0..1). Keep low until you trust it.
MAX_SPEED=0.4
# Start in autonomous mode? If false, robot only obeys manual teleop until you enable it.
AUTONOMOUS_ON_START=false

# ===== Identity / voice wake-name =====
# Address the robot by name, e.g. "Nova, go forward". Easy to change.
ROBOT_NAME=Nova
# If true, spoken commands are ignored unless they contain ROBOT_NAME.
WAKE_REQUIRED=true

# ===== Sharp IR distance sensor (backend-side safety layer) =====
# Backend also refuses 'forward' when telemetry distance_cm is below this.
# The firmware already hard-stops at SHARP_STOP_CM; this is a second net.
FRONT_STOP_CM=12

# ===== Speech (optional) =====
# TTS_MODE: none | stream  (stream renders audio and pushes to the robot; needs extra setup)
# none | pyttsx3 (offline OS voices) | piper (neural, needs PIPER_MODEL)
TTS_MODE=pyttsx3
# STT_MODE: none | whisper  (whisper requires the robot to stream mic audio; advanced)
# none | whisper  (needs faster-whisper installed AND firmware ENABLE_MIC_STREAMING=1)
STT_MODE=none
# STT_MODEL=base
# PIPER_MODEL=/path/to/voice.onnx
